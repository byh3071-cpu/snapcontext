{
  "manifest_version": 3,
  "name": "SnapContext",
  "version": "0.2.0",
  "description": "웹 UI 컨텍스트를 AI용 컨텍스트 팩으로 캡처합니다",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "action": {
    "default_title": "SnapContext",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "commands": {
    "capture-visible": {
      "suggested_key": {
        "default": "Alt+Shift+V"
      },
      "description": "Visible Capture"
    },
    "capture-element": {
      "suggested_key": {
        "default": "Alt+Shift+E"
      },
      "description": "Element Capture"
    },
    "capture-document": {
      "suggested_key": {
        "default": "Alt+Shift+M"
      },
      "description": "Document Capture"
    },
    "capture-full-page": {
      "suggested_key": {
        "default": "Alt+Shift+G"
      },
      "description": "Full Page Capture"
    },
    "copy-png": {
      "description": "Copy PNG (manual bind via whale://extensions/shortcuts; default removed because Chrome limits suggested_key entries to 4)"
    }
  },
  "permissions": [
    "sidePanel",
    "storage",
    "scripting",
    "downloads",
    "tabs",
    "windows"
  ],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content-script.ts"],
      "run_at": "document_idle"
    }
  ]
}
